# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real keys.

# Supabase — optional. Without these, the app runs in local-only mode.
# URL is safe to share. Anon key is public-by-design (RLS enforces access).
# Never put the service_role key here — it would ship in the browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
